{
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/public/sections/:path*",
      "destination": "/public/sections/:path*"
    },
    {
      "source": "/public/projects/:path*",
      "destination": "/public/projects/:path*"
    },
    {
      "source": "/public/images/:path*",
      "destination": "/public/images/:path*"
    },
    {
      "source": "/404.html",
      "destination": "/404.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}